# =============================================
# CREATIVES PRO v4 — Variables de entorno
# Copiá este archivo como .env.local
# =============================================

# --- SUPABASE (requerido) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- ANTHROPIC (requerido) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- OPENAI (opcional — para imágenes DALL-E) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- HOTMART WEBHOOK (opcional) ---
# Configurá el mismo valor en Hotmart → Ferramentas → Webhooks → Hottok
HOTMART_WEBHOOK_SECRET=tu_token_secreto_32_chars
